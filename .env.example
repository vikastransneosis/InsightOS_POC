# ─── LLM Provider ─────────────────────────────────────────────────────
# Options: "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# Gemini (default)
GOOGLE_API_KEY=
GEMINI_LLM_MODEL=gemini-2.0-flash

# OpenAI (alternative)
# OPENAI_API_KEY=
# OPENAI_LLM_MODEL=gpt-4o-mini

# ─── Embedding (local HuggingFace) ───────────────────────────────────
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DEVICE=mps          # cpu | cuda | mps (Apple Silicon)
# EMBEDDING_BATCH_SIZE=32

# ─── Vector Store (Chroma — default, persistent under storage/chroma) ─
CHROMA_COLLECTION=insightos_poc2

# Optional: Qdrant only if you use Python 3.11–3.13 and install llama-index-vector-stores-qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=insightos_chunks

# ─── Neo4j (optional: KG import + query-time graph; else kg_graph.json) ─
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# USE_NEO4J_IN_QUERY=1
# NEO4J_QUERY_LIMIT=50
# NEO4J_TEXT_TO_CYPHER=0

# ─── Chunking ────────────────────────────────────────────────────────
CHUNK_SIZES=2048,512,128
CHUNK_OVERLAP=64

# ─── Retrieval & Reranking ───────────────────────────────────────────
SIMILARITY_TOP_K=15
RERANK_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-2-v2
BM25_TOP_K=10

# ─── KG Extraction ──────────────────────────────────────────────────
KG_MAX_TRIPLETS_PER_CHUNK=15
KG_NUM_WORKERS=4

# ─── Ingestion ───────────────────────────────────────────────────────
INGEST_NUM_WORKERS=4
LOW_TEXT_CHAR_THRESHOLD=40
